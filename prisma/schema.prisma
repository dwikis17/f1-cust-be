generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

generator nodeClient {
  provider = "prisma-client"
  output   = "../src/generated/prisma-node"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductAudience {
  MEN
  WOMEN
  KIDS
  UNISEX
}

enum CollectionKind {
  DOMAIN
  TEAM
  DRIVER
  MERCHANDISE
  BRAND
  PROMOTION
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum PaymentEventProcessingResult {
  RECEIVED
  PROCESSED
  REJECTED
}

enum FulfillmentStatus {
  UNFULFILLED
  BOOKED
  BOOKING_FAILED
}

model Admin {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique
  displayName  String
  passwordSalt String
  passwordHash String
  active       Boolean        @default(true)
  sessions     AdminSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AdminSession {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  adminId   String   @db.Uuid
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([expiresAt])
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Tag {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @unique
  slug      String       @unique
  products  ProductTag[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Team {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  slug        String       @unique
  logoUrl     String?
  drivers     Driver[]
  products    Product[]
  collections Collection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Driver {
  id           String          @id @default(uuid()) @db.Uuid
  name         String          @unique
  slug         String          @unique
  racingNumber Int             @unique
  photoUrl     String?
  teamId       String?         @db.Uuid
  team         Team?           @relation(fields: [teamId], references: [id], onDelete: Restrict)
  products     ProductDriver[]
  collections  Collection[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([teamId])
}

model Product {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  nameId        String?
  slug          String              @unique
  description   String              @default("")
  descriptionId String?
  sizingNote    String?
  priceIdr      Int
  status        ProductStatus       @default(DRAFT)
  categoryId    String              @db.Uuid
  category      Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  teamId        String?             @db.Uuid
  team          Team?               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  audience      ProductAudience?
  drivers       ProductDriver[]
  collections   ProductCollection[]
  tags          ProductTag[]
  variants      ProductVariant[]
  photos        ProductPhoto[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([categoryId])
  @@index([teamId])
  @@index([audience])
  @@index([status])
  @@index([createdAt])
}

model ProductDriver {
  productId String  @db.Uuid
  driverId  String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  driver    Driver  @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@id([productId, driverId])
  @@index([driverId])
}

model Collection {
  id          String              @id @default(uuid()) @db.Uuid
  name        String
  slug        String              @unique
  kind        CollectionKind
  teamId      String?             @db.Uuid
  team        Team?               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  driverId    String?             @db.Uuid
  driver      Driver?             @relation(fields: [driverId], references: [id], onDelete: Restrict)
  parentId    String?             @db.Uuid
  parent      Collection?         @relation("CollectionTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    Collection[]        @relation("CollectionTree")
  imageUrl    String?
  description String              @default("")
  position    Int                 @default(0)
  active      Boolean             @default(true)
  products    ProductCollection[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([parentId, position])
  @@index([kind, active])
  @@index([teamId])
  @@index([driverId])
}

model ProductCollection {
  productId    String     @db.Uuid
  collectionId String     @db.Uuid
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  position     Int?
  featured     Boolean    @default(false)

  @@id([productId, collectionId])
  @@index([collectionId, position])
}

model ProductTag {
  productId String  @db.Uuid
  tagId     String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

model ProductVariant {
  id              String      @id @default(uuid()) @db.Uuid
  productId       String      @db.Uuid
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String      @unique
  size            String?
  color           String?
  stockQuantity   Int         @default(0)
  packageLengthMm Int
  packageWidthMm  Int
  packageHeightMm Int
  packageWeightG  Int
  sizingGuide     Json?
  orderItems      OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([productId])
  @@index([size])
  @@index([color])
}

model PromoCode {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique
  discountPercentage Int
  maxDiscountIdr     Int?
  active             Boolean  @default(true)
  orders             Order[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([active, createdAt])
}

model Faq {
  id         String   @id @default(uuid()) @db.Uuid
  question   String
  questionId String?
  answer     String
  answerId   String?
  position   Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, position, createdAt])
}

model Order {
  id                                String                 @id @default(uuid()) @db.Uuid
  orderNumber                       String                 @unique
  idempotencyKey                    String                 @unique @db.Uuid
  email                             String
  firstName                         String
  lastName                          String
  phone                             String
  address                           String
  city                              String
  province                          String
  postalCode                        String
  subtotalIdr                       Int
  discountIdr                       Int                    @default(0)
  shippingIdr                       Int
  totalIdr                          Int
  promoCodeId                       String?                @db.Uuid
  promoCode                         PromoCode?             @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  promoRedeemedAt                   DateTime?
  courierCode                       String
  courierName                       String
  courierServiceCode                String
  courierServiceName                String
  courierDuration                   String
  paymentStatus                     PaymentStatus          @default(PENDING)
  midtransStatus                    String                 @default("pending")
  midtransTransactionId             String?
  midtransPaymentType               String?
  midtransSnapToken                 String?
  paymentConfirmationEmailSendingAt DateTime?
  paymentConfirmationEmailSentAt    DateTime?
  stockReleasedAt                   DateTime?
  fulfillmentStatus                 FulfillmentStatus      @default(UNFULFILLED)
  biteshipOrderId                   String?                @unique
  biteshipTrackingId                String?
  biteshipWaybillId                 String?
  biteshipPriceIdr                  Int?
  biteshipStatus                    String?
  items                             OrderItem[]
  paymentEvents                     MidtransPaymentEvent[]
  createdAt                         DateTime               @default(now())
  updatedAt                         DateTime               @updatedAt

  @@index([paymentStatus, createdAt])
  @@index([fulfillmentStatus, createdAt])
  @@index([promoCodeId, createdAt])
  @@index([promoRedeemedAt])
}

model MidtransPaymentEvent {
  id                String                       @id @default(uuid()) @db.Uuid
  orderId           String                       @db.Uuid
  order             Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  statusCode        String
  grossAmount       String
  transactionStatus String
  transactionId     String?
  fraudStatus       String?
  paymentType       String?
  payload           Json
  processingResult  PaymentEventProcessingResult @default(RECEIVED)
  processingError   String?
  receivedAt        DateTime                     @default(now())
  processedAt       DateTime?

  @@index([orderId, receivedAt])
}

model OrderItem {
  id              String          @id @default(uuid()) @db.Uuid
  orderId         String          @db.Uuid
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId       String?         @db.Uuid
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName     String
  sku             String
  color           String?
  size            String?
  unitPriceIdr    Int
  quantity        Int
  packageLengthMm Int
  packageWidthMm  Int
  packageHeightMm Int
  packageWeightG  Int
  createdAt       DateTime        @default(now())

  @@index([orderId])
  @@index([variantId])
}

model ProductPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String?
  path      String   @unique
  altText   String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, position])
}
